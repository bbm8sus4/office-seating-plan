# SeatMap — deployment configuration example.
# Set these in the Cloudflare Pages dashboard, NOT in this repo. This file documents the names only;
# it must never contain real values.

# Site gate password (HTTP Basic Auth). The middleware reads ONLY this env var — no password is stored in code.
# Cloudflare Pages > your project > Settings > Environment variables > add SITE_PASSWORD.
# If unset, the site fails CLOSED (everyone gets 401) — that is intentional.
SITE_PASSWORD=

# --- KV binding for shared state (/api/state) ---
# This is a *binding name*, configured under Settings > Functions > KV namespace bindings (not an env value here).
# The functions/api/state.js handler will reference it as env.SEATMAP_KV.
# Bind your existing KV namespace to the variable name: SEATMAP_KV
# SEATMAP_KV=<bind your KV namespace to this name in the CF dashboard>
